generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  EDITOR
}

enum StoryType {
  ARTICLE
  NEWS
}

model User {
  id                  Int                  @id @default(autoincrement())
  email               String               @unique
  fullName            String
  role                Role                 @default(USER)
  stories             Story[]
  createdAt           DateTime             @default(now())
  comments            Comment[]
  bookmarks           Bookmark[]
  subscribeForASports SubscribeForASport[]
  accounts            Account[]
}

model Account {
  id                Int     @id @default(autoincrement())
  userId            Int
  user              User    @relation(fields: [userId], references: [id])
  provider          String
  providerAccountId String
  password          String? // Store hashed password here for credentials provider
}

model Story {
  id        Int        @id @default(autoincrement())
  title     String
  slug      String     @unique
  type      StoryType  @default(ARTICLE)
  excerpt   String
  content   String?
  sport     String
  topic     String
  readTime  Int // I can also calculate this on the fly based on the content length, but that way you should calculate for every request. so I prefer to calculate it once and store it in the database.
  coverUrl  String?
  published Boolean    @default(false)
  authorId  Int
  author    User       @relation(fields: [authorId], references: [id])
  createdAt DateTime   @default(now())
  comments  Comment[]
  bookmarks Bookmark[]
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id])
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model SubscribeForASport {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  sport     String
  createdAt DateTime @default(now())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}

